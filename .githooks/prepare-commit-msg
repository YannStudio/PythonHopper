#!/usr/bin/env python3
"""
Pre-commit hook to validate commit messages against Conventional Commits format.

Installation:
1. Copy this file to: .git/hooks/prepare-commit-msg
2. Make it executable: chmod +x .git/hooks/prepare-commit-msg

Or install with:
  pip install commitlint (requires Node.js)
"""

import re
import sys
from pathlib import Path

# Conventional commits pattern: type(scope): description
PATTERN = r"^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\([a-z\-]+\))?: .+"
MIN_LENGTH = 10
MAX_FIRST_LINE = 72

def check_commit_message(message: str) -> tuple[bool, str]:
    """Validate commit message format."""
    lines = message.strip().split('\n')
    
    if not lines:
        return False, "Empty commit message"
    
    first_line = lines[0]
    
    # Check length
    if len(first_line) < MIN_LENGTH:
        return False, f"Commit message too short (< {MIN_LENGTH} chars)"
    
    if len(first_line) > MAX_FIRST_LINE:
        return False, f"First line too long (> {MAX_FIRST_LINE} chars, got {len(first_line)})"
    
    # Check format
    if not re.match(PATTERN, first_line):
        return False, (
            f"Invalid commit message format. Expected: type(scope): description\n"
            f"  Got: {first_line}\n"
            f"  Types: feat, fix, docs, style, refactor, perf, test, chore, ci, revert\n"
            f"  Scope: optional, in kebab-case\n"
            f"  Example: feat(orders): add new export format"
        )
    
    # Check for breaking changes marker
    if len(lines) > 1 and "BREAKING CHANGE:" in ''.join(lines):
        if not first_line.endswith("!") and not first_line.endswith("!:"):
            if "!" not in first_line.split(":")[0]:
                # Breaking change in body but not marked in subject
                pass  # Allow, as BREAKING CHANGE: in footer is sufficient
    
    return True, "OK"

def main() -> int:
    """Validate commit message."""
    if len(sys.argv) < 2:
        return 0
    
    commit_msg_file = sys.argv[1]
    
    try:
        commit_msg = Path(commit_msg_file).read_text().strip()
    except Exception as e:
        print(f"Error reading commit message: {e}", file=sys.stderr)
        return 1
    
    # Skip merge commits and other special commits
    if commit_msg.startswith("Merge ") or commit_msg.startswith("Revert "):
        return 0
    
    valid, error = check_commit_message(commit_msg)
    
    if not valid:
        print(f"\n❌ Commit message validation failed:\n{error}\n", file=sys.stderr)
        print("💡 For more info, see: scripts/RELEASE_PROCESS.md", file=sys.stderr)
        return 1
    
    print(f"✓ Commit message valid", file=sys.stderr)
    return 0

if __name__ == "__main__":
    sys.exit(main())
